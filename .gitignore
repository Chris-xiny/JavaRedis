cat > .gitignore <<'EOF'
# ---------------------- Java & Maven ----------------------
# 编译后的文件
*.class
target/
*/target/

# Maven 临时文件
.mvn/wrapper/maven-wrapper.jar
.pom.tmp
# 日志文件
*.log
# ---------------------- IDE 特定文件 ----------------------
## IntelliJ IDEA 项目设置 (团队普遍约定忽略)
.idea/
*.iml
*.ipr
*.iws

## VS Code 项目设置
.vscode/

## Eclipse 项目设置
.settings/
.project
.classpath
# ---------------------- Spring Boot & Redis 学习 ----------------------
# 本地配置文件（通常包含敏感信息，严禁提交）
application-*.properties
application-*.yml
bootstrap-*.properties
bootstrap-*.yml

# Redis 数据持久化文件
*.rdb
*.aof
dump.rdb
appendonly.aof
# ---------------------- 操作系统 ----------------------
# Mac / Windows 系统生成
.DS_Store
Thumbs.db
EOF